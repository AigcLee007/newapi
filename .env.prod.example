# Copy this file to .env on the server and replace every placeholder.
# Never commit the real .env file.

APP_HOST_PORT=13000
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
REDIS_PASSWORD=replace-with-a-strong-redis-password
SESSION_SECRET=replace-with-a-strong-random-session-secret
TZ=Asia/Shanghai

IMAGE_ASYNC_RESULT_STORAGE=s3
IMAGE_ASYNC_S3_PROVIDER=tencent-cos
IMAGE_ASYNC_S3_ENDPOINT=https://cos.ap-hongkong.myqcloud.com
IMAGE_ASYNC_S3_REGION=ap-hongkong
IMAGE_ASYNC_S3_BUCKET=your-bucket-name-appid
IMAGE_ASYNC_S3_ACCESS_KEY_ID=your-tencent-secret-id
IMAGE_ASYNC_S3_SECRET_ACCESS_KEY=your-tencent-secret-key
IMAGE_ASYNC_S3_FORCE_PATH_STYLE=false
IMAGE_ASYNC_S3_PUBLIC_BASE_URL=https://your-bucket-name-appid.cos.ap-hongkong.myqcloud.com
IMAGE_ASYNC_S3_OBJECT_PREFIX=newapi/images/
IMAGE_ASYNC_CONVERT_B64_TO_URL=true
IMAGE_ASYNC_CACHE_UPSTREAM_URL=true
IMAGE_ASYNC_RESULT_MAX_MB=64
